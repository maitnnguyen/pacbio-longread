// ============================================================
// CVID PacBio HiFi Pipeline — Nextflow Configuration
// Platform: CSC Puhti | Executor: SLURM | Container: Singularity
// ============================================================

params {
    samplesheet   = "/home/arkku/group/ics/user_test/Mai_test/pacbio/samplesheet.csv"
    ref           = "/home/arkku/group/ics/resources/genome/human_GRCH38_gencode_v49/GRCh38.primary_assembly.genome.fa"
    outdir        = "results"
    tandem_bed    = null     // Optional: PacBio human tandem repeat BED for pbsv

    // Resource limits
    max_cpus      = 40
    max_memory    = "150.GB"
    max_time      = "72.h"
}

// ── Singularity ────────────────────────────────────────────────────────────
singularity {
    enabled        = true
    autoMounts     = true
    runOptions     = "--no-home"
}

// Path to pre-pulled SIF files — update filenames to match your actual .sif files
def SIF = "/home/arkku/group/ics/tools/singularity_cache"

// ── SLURM executor ─────────────────────────────────────────────────────────
executor {
    name           = "slurm"
    queue.         = "arkku"
    queueSize      = 50
    submitRateLimit = "10/1min"
}

// ── Process-level resource & container config ──────────────────────────────
process {
    // Default resources
    cpus   = 4
    memory = "16.GB"
    time   = "6.h"

    // Error strategy — retry once with more memory
    errorStrategy = { task.exitStatus in [130, 137, 140] ? "retry" : "finish" }
    maxRetries    = 1
    maxErrors     = "-1"

    // ── Alignment ──────────────────────────────────────────────────────────
    withName: "PBMM2_ALIGN" {
        container = "${SIF}/pbmm2.sif"
        cpus      = 16
        memory    = "64.GB"
        time      = "24.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }

    // ── SV Calling ─────────────────────────────────────────────────────────
    withName: "PBSV_DISCOVER" {
        container = "${SIF}/pbsv_2.9.0.sif"
        cpus      = 8
        memory    = "32.GB"
        time      = "12.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }
    withName: "PBSV_CALL" {
        container = "${SIF}/pbsv_2.9.0.sif"
        cpus      = 16
        memory    = "64.GB"
        time      = "24.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }
    withName: "SNIFFLES2" {
        container = "${SIF}/sniffles_2.4.sif"
        cpus      = 8
        memory    = "32.GB"
        time      = "12.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }
    withName: "SNIFFLES2_COHORT" {
        container = "${SIF}/sniffles_2.4.sif"
        cpus      = 8
        memory    = "32.GB"
        time      = "12.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }

    // ── SNV/Indel Calling ──────────────────────────────────────────────────
    withName: "DEEPVARIANT" {
        container = "${SIF}/deepvariant_latest.sif"
        cpus      = 16
        memory    = "64.GB"
        time      = "24.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }

    // ── Phasing ────────────────────────────────────────────────────────────
    withName: "HIPHASE" {
        container = "${SIF}/hiphase_1.5.0.sif"
        cpus      = 16
        memory    = "64.GB"
        time      = "24.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }

    // ── Methylation ────────────────────────────────────────────────────────
    withName: "PB_CPG_TOOLS" {
        container = "${SIF}/pb-cpg-tools_2.3.2.sif"
        cpus      = 8
        memory    = "32.GB"
        time      = "12.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }
    withName: "MODKIT_PILEUP" {
        container = "${SIF}/modkit_0.4.3.sif"
        cpus      = 8
        memory    = "32.GB"
        time      = "12.h"
        //clusterOptions = "--account=project_2xxxxxxx --partition=small"
    }
}

// ── Reports ────────────────────────────────────────────────────────────────
report {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_report.html"
}
timeline {
    enabled = true
    file    = "${params.outdir}/reports/timeline.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/reports/dag.html"
}

